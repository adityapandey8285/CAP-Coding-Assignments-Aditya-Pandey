{
  "name": "Assignment_3_Fleet_Delivery_Management_System",
  "version": "1.0.0",
  "description": "SpeedLogistics Fleet & Delivery Management System",
  "private": true,
  "scripts": {
    "start": "cds run",
    "watch": "cds watch",
    "deploy": "cds deploy --to sqlite"
  },
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4.0"
  },
  "cds": {
    "features": {
      "autoexpose": false
    },
    "requires": {
      "db": {
        "kind": "sqlite",
        "model": [
          "db",
          "srv"
        ]
      }
    }
  }
}