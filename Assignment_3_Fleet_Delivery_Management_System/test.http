  "driverId": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
  "vehicleId": "11111111-1111-1111-1111-111111111111",
  "pickupAddress": "Delhi",
  "deliveryAddress": "Gurgaon",
  "pickupCity": "Delhi",
  "deliveryCity": "Gurgaon",
  "weight": 60,
