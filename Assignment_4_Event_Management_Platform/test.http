Content-Type: application/json

{
  "event_ID": "aaaaaaaa-1111-1111-1111-aaaaaaaaaaaa",
  "attendeeName": "Test User",
  "attendeeEmail": "testuser@email.com",
  "attendeePhone": "9999999999",
  "company": "TCS",
  "ticketType": "General",
  "registrationDate": "2026-05-30",
